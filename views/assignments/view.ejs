<%- include('../partials/header', { title: assignment.title }) %>

<div class="container">
  <div style="max-width: 800px; margin: 0 auto;">
    <a href="/classes/<%= assignment.class_id %>" style="color: #1f73e6; text-decoration: none;">← Back to Class</a>

    <div class="card" style="margin-top: 1.5rem;">
      <div class="card-header">
        <div>
          <h1><%= assignment.title %></h1>
          <p class="text-muted"><%= class.name %></p>
        </div>
        <% if (isTeacher) { %>
          <div>
            <a href="/assignments/<%= assignment.id %>/edit" class="btn btn-secondary">Edit</a>
          </div>
        <% } %>
      </div>

      <div class="card-body">
        <h3>Instructions</h3>
        <p><%= assignment.description || 'No instructions provided' %></p>

        <% if (assignment.due_date) { %>
          <h3 style="margin-top: 2rem;">Due Date</h3>
          <p><%= new Date(assignment.due_date).toLocaleString() %></p>
        <% } %>

        <h3 style="margin-top: 2rem;">Points</h3>
        <p><%= assignment.max_points %> points</p>
      </div>
    </div>

    <% if (isTeacher) { %>
      <!-- Teacher View: Submissions -->
      <h2 style="margin-top: 2rem;">Submissions (<%= submissions.length %>)</h2>
      <% if (submissions.length > 0) { %>
        <% submissions.forEach(submission => { %>
          <div class="submission-item">
            <div class="submission-header">
              <div>
                <p class="submission-student"><%= submission.first_name %> <%= submission.last_name %></p>
                <p class="text-muted">Submitted <%= new Date(submission.submitted_at).toLocaleString() %></p>
              </div>
              <% if (submission.status === 'graded') { %>
                <span class="submission-status graded"><%= submission.points %>/<%= assignment.max_points %> pts</span>
              <% } else { %>
                <span class="submission-status submitted">Submitted</span>
              <% } %>
            </div>
            <p><%= submission.submission_text %></p>
            <% if (submission.feedback) { %>
              <p><strong>Feedback:</strong> <%= submission.feedback %></p>
            <% } %>
          </div>
        <% }); %>
      <% } else { %>
        <p class="text-muted">No submissions yet.</p>
      <% } %>
    <% } %>
  </div>
</div>

<%- include('../partials/footer') %>
